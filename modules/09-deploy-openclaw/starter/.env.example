# OpenClaw Stack -- Non-Secret Configuration
# Copy this file to .env and edit the values.
#
# IMPORTANT: This file is for non-sensitive config only.
# API keys and tokens go in the secrets/ directory as individual files.

# User/group ID for file ownership (run `id` to check yours)
PUID=1000
PGID=1000

# Timezone -- set to your local timezone
# Examples: UTC, Europe/Istanbul, America/New_York, Asia/Tokyo
# Full list: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=UTC

# SearXNG URL -- don't change this unless you renamed the service
# Uses the Docker network hostname (the service name from docker-compose.yml)
SEARXNG_BASE_URL=http://searxng:8080
