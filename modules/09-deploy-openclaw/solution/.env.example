# OpenClaw Stack -- Non-Secret Configuration
#
# This file contains non-sensitive settings loaded by the openclaw service.
# API keys and tokens belong in secrets/ as individual files.

# Match your host user's UID/GID (run `id` to check)
PUID=1000
PGID=1000

# Your local timezone for accurate log timestamps
TZ=Europe/Istanbul

# SearXNG internal URL (Docker network hostname)
SEARXNG_BASE_URL=http://searxng:8080
