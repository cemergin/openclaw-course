# SSH Config Template for OpenClaw VPS
# ======================================
#
# Copy this file to ~/.ssh/config on your LOCAL machine:
#
#   cp ssh-config-template ~/.ssh/config
#
# Then customize the values below and set permissions:
#
#   chmod 644 ~/.ssh/config
#
# After that, you can connect with just: ssh openclaw
#

Host openclaw
    # TODO: Replace with your VPS static IP address from Module 2
    HostName YOUR_VPS_IP_HERE

    # TODO: Set to the username on your server (ubuntu for Lightsail)
    User ubuntu

    # TODO: Set to the path of your private key from Exercise Step 1
    IdentityFile ~/.ssh/openclaw

    # The SSH port (default is 22; change if you modified it in Task 3)
    Port 22

    # Keep the connection alive -- sends a ping every 60 seconds
    # so your session doesn't drop when you step away
    ServerAliveInterval 60
    ServerAliveCountMax 3
